# =============================================
# AI Monitor — Environment Variables
# Copy this file to .env.local and fill in values
# =============================================

# --- Free APIs (get these first) ---
# GitHub: github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=ghp_your_token_here

# HuggingFace: huggingface.co/settings/tokens (free account)
HUGGINGFACE_TOKEN=hf_your_token_here

# Google AI: aistudio.google.com (free, no card needed)
GOOGLE_AI_KEY=AIza_your_key_here

# --- Paid APIs (add later) ---
OPENAI_API_KEY=sk-your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Database (neon.tech — free tier) ---
DATABASE_URL=postgresql://user:password@host/model_radar

# --- Cache (upstash.com — free tier) ---
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# --- App Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate_a_long_random_string_here

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
